# Firebase (cliente web)
NEXT_FIREBASE_API_KEY=
NEXT_FIREBASE_AUTH_DOMAIN=
NEXT_FIREBASE_PROJECT_ID=
NEXT_FIREBASE_STORAGE_BUCKET=
NEXT_FIREBASE_MESSAGING_SENDER_ID=
NEXT_FIREBASE_APP_ID=
NEXT_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (backend)
# Importante: usa valores planos (sin comillas ni coma final), excepto PRIVATE_KEY.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alias opcionales para backend (si prefieres mantener prefijo NEXT_FIREBASE_):
# NEXT_FIREBASE_CLIENT_EMAIL=
# NEXT_FIREBASE_PRIVATE_KEY=

# Base de datos (Prisma)
DATABASE_URL=

# Opcional: token para endpoints de GitHub con mayor límite
GITHUB_TOKEN=

# Billing (BigQuery export de Google Cloud Billing)
# Formato: project.dataset.table (se permite wildcard en table, por ejemplo gcp_billing_export_v1_*)
GOOGLE_BILLING_EXPORT_TABLE=
# Opcional: proyecto donde ejecutar la consulta (si no se define, usa FIREBASE_PROJECT_ID)
GOOGLE_BILLING_QUERY_PROJECT_ID=
# Opcional: ubicación del dataset de BigQuery (US, EU, us-central1, etc.)
GOOGLE_BILLING_BQ_LOCATION=

# MCP (opcional pero recomendado)
# Si se define, /api/mcp exigirá Authorization: Bearer <token> o X-MCP-Token.
MCP_SERVER_TOKEN=

# Trading bot (Binance Futures)
# Nota: la configuración no sensible está en config/trading-futures.json
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Token para endpoint cron del scheduler
TRADING_SCHEDULER_TOKEN=
# Alternativa recomendada en Vercel Cron (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
