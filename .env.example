# Desarrollo local:
# usa solo `.env.local`
# no uses `.env`
# no guardes aquí `VERCEL_OIDC_TOKEN`

# Variables públicas para cliente Nuxt/Firebase
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin / servidor
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# Base de datos (Prisma)
DATABASE_URL=

# Opcional: token para GitHub API
GITHUB_TOKEN=

# Billing (no son credenciales, pero el proyecto los sigue leyendo por env)
GOOGLE_BILLING_EXPORT_TABLE=
GOOGLE_BILLING_QUERY_PROJECT_ID=
GOOGLE_BILLING_BQ_LOCATION=

# Webhook n8n (trátalo como secreto)
N8N_COPY_WEBHOOK_URL=

# MCP
MCP_SERVER_TOKEN=

# Trading
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Cron / scheduler
CRON_SECRET=
TRADING_SCHEDULER_TOKEN=

# YouTube Music
YTMUSIC_COOKIE=
YTMUSIC_USER_AGENT=
YTMUSIC_ACCOUNT_ID=
